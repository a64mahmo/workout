# Database (prod uses Railway PostgreSQL — set in .env)
# For local dev, create a .env.local that overrides this:
#   DATABASE_URL="sqlite+aiosqlite:///./workout_dev.db"
DATABASE_URL="sqlite+aiosqlite:///./workout.db"

# Fitbit OAuth (optional - get these from https://dev.fitbit.com)
FITBIT_CLIENT_ID=""
FITBIT_CLIENT_SECRET=""
FITBIT_REDIRECT_URI="http://localhost:3000/settings/fitbit/callback"
